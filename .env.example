# Supabase — get values from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — required for the WhatsApp digest cron (server only, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres pooler URI — required for auto-migrations on dev/build/start
# Supabase → Project Settings → Database → Connection string → Session pooler (port 5432)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# Public site URL used in digest links (production: https://iao.today)
NEXT_PUBLIC_SITE_URL=https://iao.today

# Resend — get API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Your inbox — where contact form messages are delivered
# With onboarding@resend.dev, this MUST match your Resend account email until you verify a domain
CONTACT_TO_EMAIL=you@example.com
# After verifying iao.today in Resend, use e.g. IAO Today <hello@iao.today>
# Until then, use Resend's test sender: IAO Today <onboarding@resend.dev>
RESEND_FROM_EMAIL=IAO Today <onboarding@resend.dev>

# Vercel Cron auth — set in Vercel env vars; daily cron at 10:00 AM Asia/Manila (Hobby: once/day, ±59 min)
# Uptime Robot / external trigger: GET https://www.iao.today/api/cron/whatsapp-digest/trigger?key=YOUR_CRON_SECRET
# Instagram scrape (every 12h): GET https://www.iao.today/api/cron/instagram-scrape/trigger?key=YOUR_CRON_SECRET
# Reset instagram data + re-scrape: pnpm instagram:reset  (uses DATABASE_URL + NEXT_PUBLIC_SITE_URL from .env.local)
CRON_SECRET=generate-a-long-random-string

# Apify — get token from console.apify.com/account/integrations
# Used by apify/instagram-scraper to fetch latest posts for monitored accounts
APIFY_API_TOKEN=apify_api_xxxxxxxx
# Local webhook testing: set NEXT_PUBLIC_SITE_URL to your ngrok URL so Apify can POST results back
# Production webhook: https://www.iao.today/api/webhooks/apify?key=YOUR_CRON_SECRET&username=...

# OpenRouter — get key from openrouter.ai/keys
# Used to classify and extract events from Instagram posts (openai/gpt-4o-mini)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# WhatsApp daily channel digest
# Step 1: Meta Business + WhatsApp Cloud API (developers.facebook.com)
#   - Create a Meta Business account at business.facebook.com
#   - Create a Developer App → Business type → add WhatsApp product
#   - In WhatsApp → API Setup, copy Phone Number ID and generate an access token
#   - For production, create a System User in Business Manager and a permanent token
# Note: Meta Cloud API cannot post to WhatsApp Channels yet. Use a channel gateway below.
#
# Step 2: Channel gateway (e.g. Whapi.Cloud) linked to the same WhatsApp Business number
#   - Connect your WhatsApp account via QR in the gateway dashboard
#   - Copy your channel recipient ID (often looks like 120363...@newsletter)
#   - Gateway settings (digestEnabled, dryRun, apiBaseUrl, etc.) live in lib/whatsapp/whapi.config.ts
#
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_CHANNEL_RECIPIENT_ID=

# Vercel production — add all vars above plus DATABASE_URL in Project → Settings → Environment Variables, then deploy.
# Local digest testing: pnpm dev, then pnpm digest:preview or pnpm digest:send
